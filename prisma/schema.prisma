// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

// ตั้งค่าให้ใช้ PostgreSQL บน Cloud (Neon / Vercel)
datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL") // เปลี่ยนจาก DATABASE_URL เป็นชื่อนี้แทน
}

// ==========================================
// 1. ตารางแอดมิน (Admin Users)
// ==========================================
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // เก็บแบบเข้ารหัส (Hashed)
  name      String?
  createdAt DateTime @default(now())
}

// ==========================================
// 2. ตารางข้อมูลพัสดุ (Tracking Data)
// ==========================================
model Tracking {
  id                String   @id @default(cuid())
  trackingNumber    String   @unique
  currentStatus     String   @default("PENDING")
  origin            String
  destination       String
  sender            String
  receiver          String
  estimatedDelivery String
  serviceType       String
  pieces            Int
  weight            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // บรรทัดนี้เพิ่มมาเพื่อผูกกับตารางประวัติ
  trackingHistories TrackingHistory[] 
}

// ==========================================
// 3. ตารางประวัติสถานะ (Tracking History)
// ==========================================
model TrackingHistory {
  id             String   @id @default(cuid())
  trackingNumber String?
  status         String
  location       String?
  description    String?
  parcelId       String?
  createdAt      DateTime @default(now())

  // บรรทัดนี้เพิ่มมาเพื่อผูกกลับไปหาตารางหลัก
  parcel         Tracking? @relation(fields: [parcelId], references: [id])
}
// ==========================================
// 📰 ตารางสำหรับจัดการข่าวสาร (News & Activities)
// ==========================================
model News {
  id        Int      @id @default(autoincrement())
  title     String
  status    String   @default("PUBLISHED") // สถานะ: PUBLISHED (เผยแพร่), HIDDEN (ซ่อน)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 📝 ตารางสำหรับเก็บคำขอใบเสนอราคา (Quotations)
// ==========================================
model Quotation {
  id        Int      @id @default(autoincrement())
  qNumber   String   @unique 
  name      String
  company   String?
  service   String
  status    String   @default("PENDING") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
// ==========================================
// 3. ตารางระบบคลังเอกสาร (e-Document)
// ==========================================
model Document {
  id        Int      @id @default(autoincrement())
  title     String   // ชื่อเอกสาร
  category  String   // หมวดหมู่ (HR, Finance, ฯลฯ)
  size      String   // ขนาดไฟล์
  type      String   // ประเภทไฟล์ (PDF, Excel, Word)
  icon      String   // ไอคอน
  color     String   // สีไอคอน
  fileUrl   String?  // ลิงก์ไฟล์บน Vercel Blob
  createdAt DateTime @default(now()) // วันที่อัปโหลด
}