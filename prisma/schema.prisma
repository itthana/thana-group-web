// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

// ตั้งค่าให้ใช้ PostgreSQL บน Cloud (Neon / Vercel)
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ==========================================
// 1. ตารางแอดมิน (Admin Users)
// ==========================================
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // เก็บแบบเข้ารหัส (Hashed)
  name      String?
  createdAt DateTime @default(now())
}

// ==========================================
// 2. ตารางข้อมูลพัสดุ (Tracking Data)
// ==========================================
model Tracking {
  id                String   @id @default(cuid())
  trackingNumber    String   @unique
  currentStatus     String   @default("PENDING")
  origin            String
  destination       String
  sender            String
  receiver          String
  estimatedDelivery String
  serviceType       String
  pieces            Int
  weight            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // บรรทัดนี้เพิ่มมาเพื่อผูกกับตารางประวัติ
  trackingHistories TrackingHistory[] 
}

// ==========================================
// 3. ตารางประวัติสถานะ (Tracking History)
// ==========================================
model TrackingHistory {
  id             String   @id @default(cuid())
  trackingNumber String?
  status         String
  location       String?
  description    String?
  parcelId       String?
  createdAt      DateTime @default(now())

  // บรรทัดนี้เพิ่มมาเพื่อผูกกลับไปหาตารางหลัก
  parcel         Tracking? @relation(fields: [parcelId], references: [id])
}
